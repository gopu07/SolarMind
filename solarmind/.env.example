# ─── SolarMind AI — Environment Variables ─────────────────────────
# Copy this file to .env and fill in the values.

# ── OpenAI / LLM ──────────────────────────────────────────────────
# API key for GPT-4/OpenRouter narrative generation and embeddings
OPENAI_API_KEY=sk-or-v1-your-key-here
# Optional base URL for providers like OpenRouter
OPENAI_BASE_URL=https://openrouter.ai/api/v1
# Chat model used for diagnostic narratives (e.g., meta-llama/llama-3-8b-instruct)
LLM_MODEL=meta-llama/llama-3-8b-instruct
# Embedding model used for RAG vector store
EMBEDDING_MODEL=text-embedding-3-small

# ── Authentication ────────────────────────────────────────────────
# Secret key for signing JWT tokens (change in production!)
JWT_SECRET=change-me-in-production
# Dev credentials for the /auth/token endpoint
DEV_USERNAME=admin
DEV_PASSWORD=admin

# ── External Services ─────────────────────────────────────────────
# CMMS ticket creation endpoint (mock stub runs on 8001)
CMMS_ENDPOINT=http://localhost:8001/tickets
# Slack webhook for alert notifications (leave empty to skip)
SLACK_WEBHOOK_URL=
# Redis connection for report caching (leave empty for in-memory fallback)
REDIS_URL=

# ── Logging ───────────────────────────────────────────────────────
LOG_LEVEL=INFO
